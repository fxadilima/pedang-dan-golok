---
interface Props {
    // Kita tetap pertahankan prop jika di masa depan butuh link dinamis (misal: Daftar Bab internal)
    links?: { text: string; href: string }[];
}

const { links = [] } = Astro.props;
---

<aside id="sidebar">
    <!-- DESKTOP SIDEBAR (Hidden on Small Screens) -->
    <nav class="w3-sidebar w3-bar-block w3-small w3-hide-small w3-center w3-black">
        <!-- Logo / Aksara Wuxia -->
        <a href="/" class="w3-bar-item w3-padding-large w3-hover-black">
            <img src="/images/logo.png" alt="Logo" style="width:100%" />
        </a>

        <!-- Menu Utama Global -->
        <a href="/" class="w3-bar-item w3-button w3-padding-large w3-hover-black">
            <i class="fa fa-home w3-xxlarge"></i>
            <p>HOME</p>
        </a>

        <!-- Jika halaman MD/MDX mengirimkan link dinamis (misal daftar bab spesifik buku itu) -->
        {
            links.map((link) => (
                <a href={link.href} class="w3-bar-item w3-button w3-padding-large w3-hover-black">
                    <i class="fa fa-bookmark w3-xxlarge" />
                    <p>{link.text}</p>
                </a>
            ))
        }
    </nav>

    <!-- MOBILE NAVBAR (Hidden on Medium & Large Screens) -->
    <div class="w3-top w3-hide-large w3-hide-medium w3-black" id="myNavbar">
        <div class="w3-bar w3-black w3-opacity w3-hover-opacity-off w3-center w3-small">
            <!-- Home Button -->
            <a href="/" class="w3-bar-item w3-button w3-padding-large">
                <i class="fa fa-home"></i> HOME
            </a>
            
            <!-- Jika ada link aktif dari bab, dia akan muncul ringkas di sampingnya -->
            {
                links.map((link) => (
                    <a href={link.href} class="w3-bar-item w3-button w3-padding-large">
                        <i class="fa fa-bookmark"></i> {link.text}
                    </a>
                ))
            }
        </div>
    </div>
</aside>

<style>
    /* Memastikan konten utama tidak tertutup navbar mobile di layar portrait */
    @media max-width: 600px) {
        #sidebar {
            margin-bottom: 50px;
        }
    }
</style>
