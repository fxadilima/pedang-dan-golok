---
import Sidebar from '../components/Sidebar4.astro';

const { frontmatter } = Astro.props;

---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{frontmatter.title}</title>
  <meta name="description" content={frontmatter.description}>
  <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
  <link rel="stylesheet" href="/styles/main.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Montserrat">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
</head>
<body class="w3-black">
   <Sidebar links={[
      { text: 'Blogs', href: '/blog' },
      { text: 'Book 1', href: '/book/1/1' },
      { text: 'Book 2', href: '/book/2/1' },
      { text: 'Book 3', href: '/book/3/1' },
      { text: 'Book 4', href: '/book/4/1' },
      { text: 'Book 5', href: '/book/5/1' }
    ]} />
	
	<main class="w3-container w3-padding-large" id="main" aria-label="Content">
		<header>
			<h1>{frontmatter.title}</h1>
		</header>
	
		<hr>
		
		<slot />
		<footer>
			<p>Copyright, &copy; 2026 FX. Adi Lima</p>
		</footer>
    </main>
</body>
</html>
